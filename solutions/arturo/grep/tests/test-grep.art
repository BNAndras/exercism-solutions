import.version:3.0.0 {unitt}!

write {
    Achilles sing, O Goddess! Peleus' son;
    His wrath pernicious, who ten thousand woes
    Caused to Achaia's host, sent many a soul
    Illustrious into Ades premature,
    And Heroes gave (so stood the will of Jove)
    To dogs and to all ravening fowls a prey,
    When fierce dispute had separated once
    The noble Chief Achilles from the son
    Of Atreus, Agamemnon, King of men.
} "iliad.txt"

write {
    I do entreat your grace to pardon me.
    I know not by what power I am made bold,
    Nor how it may concern my modesty,
    In such a presence here to plead my thoughts;
    But I beseech your grace that I may know
    The worst that may befall me in this case,
    If I refuse to wed Demetrius.
} "midsummer-night.txt"

write {
    Of Mans First Disobedience, and the Fruit
    Of that Forbidden Tree, whose mortal tast
    Brought Death into the World, and all our woe,
    With loss of Eden, till one greater Man
    Restore us, and regain the blissful Seat,
    Sing Heav'nly Muse, that on the secret top
    Of Oreb, or of Sinai, didst inspire
    That Shepherd, who first taught the chosen Seed
} "paradise-lost.txt"

Grep: function [pattern][
    flags: attr 'flags
    files: attr 'files
    if null? flags -> flags: []
    if null? files -> files: []

    args: ["src/grep.art"] ++ flags ++ @[pattern] ++ files
    strip.end execute.args:args sys\binary
]

describe "Grep" [
    describe "Test grepping a single file" [
        it "One file, one match, no flags" [
            expects.be:'equal? @[
                "Of Atreus, Agamemnon, King of men."
                Grep.flags:[] .files:["iliad.txt"] "Agamemnon"
            ]
        ]

        it.skip "One file, one match, print line numbers flag" [
            expects.be:'equal? @[
                "2:Of that Forbidden Tree, whose mortal tast"
                Grep.flags:["-n"] .files:["paradise-lost.txt"] "Forbidden"
            ]
        ]

        it.skip "One file, one match, case-insensitive flag" [
            expects.be:'equal? @[
                "Of that Forbidden Tree, whose mortal tast"
                Grep.flags:["-i"] .files:["paradise-lost.txt"] "FORBIDDEN"
            ]
        ]

        it.skip "One file, one match, print file names flag" [
            expects.be:'equal? @[
                "paradise-lost.txt"
                Grep.flags:["-l"] .files:["paradise-lost.txt"] "Forbidden"
            ]
        ]

        it.skip "One file, one match, match entire lines flag" [
            expects.be:'equal? @[
                "With loss of Eden, till one greater Man"
                Grep.flags:["-x"] .files:["paradise-lost.txt"] "With loss of Eden, till one greater Man"
            ]
        ]

        it.skip "One file, one match, multiple flags" [
            expects.be:'equal? @[
                "9:Of Atreus, Agamemnon, King of men."
                Grep.flags:["-n" "-i" "-x"] .files:["iliad.txt"] "OF ATREUS, Agamemnon, KIng of MEN."
            ]
        ]

        it.skip "One file, several matches, no flags" [
            expects.be:'equal? @[
                {
                    Nor how it may concern my modesty,
                    But I beseech your grace that I may know
                    The worst that may befall me in this case,
                }
                Grep.flags:[] .files:["midsummer-night.txt"] "may"
            ]
        ]

        it.skip "One file, several matches, print line numbers flag" [
            expects.be:'equal? @[
                {
                    3:Nor how it may concern my modesty,
                    5:But I beseech your grace that I may know
                    6:The worst that may befall me in this case,
                }
                Grep.flags:["-n"] .files:["midsummer-night.txt"] "may"
            ]
        ]

        it.skip "One file, several matches, match entire lines flag" [
            expects.be:'equal? @[
                ""
                Grep.flags:["-x"] .files:["midsummer-night.txt"] "may"
            ]
        ]

        it.skip "One file, several matches, case-insensitive flag" [
            expects.be:'equal? @[
                {
                    Achilles sing, O Goddess! Peleus' son;
                    The noble Chief Achilles from the son
                }
                Grep.flags:["-i"] .files:["iliad.txt"] "ACHILLES"
            ]
        ]

        it.skip "One file, several matches, inverted flag" [
            expects.be:'equal? @[
                {
                    Brought Death into the World, and all our woe,
                    With loss of Eden, till one greater Man
                    Restore us, and regain the blissful Seat,
                    Sing Heav'nly Muse, that on the secret top
                    That Shepherd, who first taught the chosen Seed
                }
                Grep.flags:["-v"] .files:["paradise-lost.txt"] "Of"
            ]
        ]

        it.skip "One file, no matches, various flags" [
            expects.be:'equal? @[
                ""
                Grep.flags:["-n" "-l" "-x" "-i"] .files:["iliad.txt"] "Gandalf"
            ]
        ]

        it.skip "One file, one match, file flag takes precedence over line flag" [
            expects.be:'equal? @[
                "iliad.txt"
                Grep.flags:["-n" "-l"] .files:["iliad.txt"] "ten"
            ]
        ]

        it.skip "One file, several matches, inverted and match entire lines flags" [
            expects.be:'equal? @[
                {
                    Achilles sing, O Goddess! Peleus' son;
                    His wrath pernicious, who ten thousand woes
                    Caused to Achaia's host, sent many a soul
                    And Heroes gave (so stood the will of Jove)
                    To dogs and to all ravening fowls a prey,
                    When fierce dispute had separated once
                    The noble Chief Achilles from the son
                    Of Atreus, Agamemnon, King of men.
                }
                Grep.flags:["-x" "-v"] .files:["iliad.txt"] "Illustrious into Ades premature,"
            ]
        ]
    ]

    describe "Test grepping multiple files at once" [
        it.skip "Multiple files, one match, no flags" [
            expects.be:'equal? @[
                "iliad.txt:Of Atreus, Agamemnon, King of men."
                Grep.flags:[] .files:["iliad.txt" "midsummer-night.txt" "paradise-lost.txt"] "Agamemnon"
            ]
        ]

        it.skip "Multiple files, several matches, no flags" [
            expects.be:'equal? @[
                {
                    midsummer-night.txt:Nor how it may concern my modesty,
                    midsummer-night.txt:But I beseech your grace that I may know
                    midsummer-night.txt:The worst that may befall me in this case,
                }
                Grep.flags:[] .files:["iliad.txt" "midsummer-night.txt" "paradise-lost.txt"] "may"
            ]
        ]

        it.skip "Multiple files, several matches, print line numbers flag" [
            expects.be:'equal? @[
                {
                    midsummer-night.txt:5:But I beseech your grace that I may know
                    midsummer-night.txt:6:The worst that may befall me in this case,
                    paradise-lost.txt:2:Of that Forbidden Tree, whose mortal tast
                    paradise-lost.txt:6:Sing Heav'nly Muse, that on the secret top
                }
                Grep.flags:["-n"] .files:["iliad.txt" "midsummer-night.txt" "paradise-lost.txt"] "that"
            ]
        ]

        it.skip "Multiple files, one match, print file names flag" [
            expects.be:'equal? @[
                {
                    iliad.txt
                    paradise-lost.txt
                }
                Grep.flags:["-l"] .files:["iliad.txt" "midsummer-night.txt" "paradise-lost.txt"] "who"
            ]
        ]

        it.skip "Multiple files, several matches, case-insensitive flag" [
            expects.be:'equal? @[
                {
                    iliad.txt:Caused to Achaia's host, sent many a soul
                    iliad.txt:Illustrious into Ades premature,
                    iliad.txt:And Heroes gave (so stood the will of Jove)
                    iliad.txt:To dogs and to all ravening fowls a prey,
                    midsummer-night.txt:I do entreat your grace to pardon me.
                    midsummer-night.txt:In such a presence here to plead my thoughts;
                    midsummer-night.txt:If I refuse to wed Demetrius.
                    paradise-lost.txt:Brought Death into the World, and all our woe,
                    paradise-lost.txt:Restore us, and regain the blissful Seat,
                    paradise-lost.txt:Sing Heav'nly Muse, that on the secret top
                }
                Grep.flags:["-i"] .files:["iliad.txt" "midsummer-night.txt" "paradise-lost.txt"] "TO"
            ]
        ]

        it.skip "Multiple files, several matches, inverted flag" [
            expects.be:'equal? @[
                {
                    iliad.txt:Achilles sing, O Goddess! Peleus' son;
                    iliad.txt:The noble Chief Achilles from the son
                    midsummer-night.txt:If I refuse to wed Demetrius.
                }
                Grep.flags:["-v"] .files:["iliad.txt" "midsummer-night.txt" "paradise-lost.txt"] "a"
            ]
        ]

        it.skip "Multiple files, one match, match entire lines flag" [
            expects.be:'equal? @[
                "midsummer-night.txt:But I beseech your grace that I may know"
                Grep.flags:["-x"] .files:["iliad.txt" "midsummer-night.txt" "paradise-lost.txt"] "But I beseech your grace that I may know"
            ]
        ]

        it.skip "Multiple files, one match, multiple flags" [
            expects.be:'equal? @[
                "paradise-lost.txt:4:With loss of Eden, till one greater Man"
                Grep.flags:["-n" "-i" "-x"] .files:["iliad.txt" "midsummer-night.txt" "paradise-lost.txt"] "WITH LOSS OF EDEN, TILL ONE GREATER MAN"
            ]
        ]

        it.skip "Multiple files, no matches, various flags" [
            expects.be:'equal? @[
                ""
                Grep.flags:["-n" "-l" "-x" "-i"] .files:["iliad.txt" "midsummer-night.txt" "paradise-lost.txt"] "Frodo"
            ]
        ]

        it.skip "Multiple files, several matches, file flag takes precedence over line number flag" [
            expects.be:'equal? @[
                {
                    iliad.txt
                    paradise-lost.txt
                }
                Grep.flags:["-n" "-l"] .files:["iliad.txt" "midsummer-night.txt" "paradise-lost.txt"] "who"
            ]
        ]

        it.skip "Multiple files, several matches, inverted and match entire lines flags" [
            expects.be:'equal? @[
                {
                    iliad.txt:Achilles sing, O Goddess! Peleus' son;
                    iliad.txt:His wrath pernicious, who ten thousand woes
                    iliad.txt:Caused to Achaia's host, sent many a soul
                    iliad.txt:And Heroes gave (so stood the will of Jove)
                    iliad.txt:To dogs and to all ravening fowls a prey,
                    iliad.txt:When fierce dispute had separated once
                    iliad.txt:The noble Chief Achilles from the son
                    iliad.txt:Of Atreus, Agamemnon, King of men.
                    midsummer-night.txt:I do entreat your grace to pardon me.
                    midsummer-night.txt:I know not by what power I am made bold,
                    midsummer-night.txt:Nor how it may concern my modesty,
                    midsummer-night.txt:In such a presence here to plead my thoughts;
                    midsummer-night.txt:But I beseech your grace that I may know
                    midsummer-night.txt:The worst that may befall me in this case,
                    midsummer-night.txt:If I refuse to wed Demetrius.
                    paradise-lost.txt:Of Mans First Disobedience, and the Fruit
                    paradise-lost.txt:Of that Forbidden Tree, whose mortal tast
                    paradise-lost.txt:Brought Death into the World, and all our woe,
                    paradise-lost.txt:With loss of Eden, till one greater Man
                    paradise-lost.txt:Restore us, and regain the blissful Seat,
                    paradise-lost.txt:Sing Heav'nly Muse, that on the secret top
                    paradise-lost.txt:Of Oreb, or of Sinai, didst inspire
                    paradise-lost.txt:That Shepherd, who first taught the chosen Seed
                }
                Grep.flags:["-x" "-v"] .files:["iliad.txt" "midsummer-night.txt" "paradise-lost.txt"] "Illustrious into Ades premature,"
            ]
        ]
    ]
]
